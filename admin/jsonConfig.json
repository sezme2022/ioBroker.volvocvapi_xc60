{
  "type": "tabs",
  "items": {
    "api": {
      "label": "API / Auth",
      "items": {
        "intro": {
          "type": "staticText",
          "text": "Bitte Volvo-Zugangsdaten und API-Daten eintragen. Für den Dauerbetrieb ist Refresh Token + Client ID + Client Secret der empfohlene Weg.",
          "newLine": true
        },
        "apiKey": {
          "type": "text",
          "label": "VCC API Key"
        },
        "clientId": {
          "type": "text",
          "label": "Client ID"
        },
        "clientSecret": {
          "type": "password",
          "label": "Client Secret"
        },
        "refreshToken": {
          "type": "password",
          "label": "Refresh Token"
        },
        "accessToken": {
          "type": "password",
          "label": "Access Token (optional)"
        }
      }
    },

    "vehicle": {
      "label": "Fahrzeug",
      "items": {
        "vin": {
          "type": "text",
          "label": "Vehicle VIN"
        },
        "pollIntervalSec": {
          "type": "number",
          "label": "Polling Intervall (Sekunden)",
          "min": 60,
          "max": 3600
        },
        "slowCycleCount": {
          "type": "number",
          "label": "Langsame Endpunkte nur jede N-te Runde",
          "min": 1,
          "max": 144
        }
      }
    },

    "options": {
      "label": "Optionen",
      "items": {
        "enableEnergy": {
          "type": "checkbox",
          "label": "Energy API aktivieren"
        },
        "enableLocation": {
          "type": "checkbox",
          "label": "Location API aktivieren"
        },
        "includeRawJson": {
          "type": "checkbox",
          "label": "Raw JSON speichern"
        },
        "enableDebug": {
          "type": "checkbox",
          "label": "Debug Logging aktivieren"
        }
      }
    }
  }
}
